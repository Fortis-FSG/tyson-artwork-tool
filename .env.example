# xAI API key for Grok image generation
# Get yours at https://console.x.ai
XAI_API_KEY=your_xai_api_key_here

# Vercel Blob credentials for persisting saved requests and concept images
# Private stores work (app uses access: 'private' + signed URLs).
# Create at https://vercel.com/docs/storage/vercel-blob
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...
BLOB_STORE_ID=store_...

# Shared secret for team access to the internal tool.
# Leave unset for local development without a gate.
TEAM_ACCESS_TOKEN=
